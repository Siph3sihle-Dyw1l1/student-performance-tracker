<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>AddStudentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.AddStudentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetStatsServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GetStatsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetStudentByAgeServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GetStudentByAgeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetStudentByIDServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GetStudentByIDServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetStudentByNameNSurnameServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GetStudentByNameNSurnameServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStudentServlet</servlet-name>
        <url-pattern>/AddStudentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetStatsServlet</servlet-name>
        <url-pattern>/GetStatsServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetStudentByAgeServlet</servlet-name>
        <url-pattern>/GetStudentByAgeServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetStudentByIDServlet</servlet-name>
        <url-pattern>/GetStudentByIDServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetStudentByNameNSurnameServlet</servlet-name>
        <url-pattern>/GetStudentByNameNSurnameServlet.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
